---
import SectionHeader from "@components/SectionHeader.astro";
import { ecosystemNodes } from "@data/content";
---

<section class="section-band ecosystem" id="ecosystem" aria-labelledby="ecosystem-title">
  <div class="section-grid-bg" aria-hidden="true"></div>
  <div class="container ecosystem-layout">
    <SectionHeader
      id="ecosystem-title"
      eyebrow="Network Layer"
      title="A small network for"
      highlight="useful momentum."
      description="Torix Network connects technical delivery with creators, communities, founders, and operators who are trying to get real projects into the world."
    />

    <div class="ecosystem-strip reveal" aria-hidden="true">
      <span>Scope</span>
      <strong>Torix Network</strong>
      <span>Ship</span>
      <span>Operate</span>
    </div>

    <div class="ecosystem-grid">
      {ecosystemNodes.map((node) => (
        <article class="ecosystem-card reveal">
          <h3>{node.title}</h3>
          <p>{node.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
