---
import SectionHeader from "@components/SectionHeader.astro";
import { processSteps } from "@data/content";
---

<section class="section-band process" id="process" aria-labelledby="process-title">
  <div class="section-grid-bg" aria-hidden="true"></div>
  <div class="container">
    <SectionHeader
      id="process-title"
      eyebrow="Delivery Rhythm"
      title="A simple path from"
      highlight="scope to release."
      description="Enough structure to protect quality, enough flexibility to keep decisions moving."
    />

    <ol class="process-list">
      {processSteps.map((step, index) => (
        <li class="process-step reveal">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
