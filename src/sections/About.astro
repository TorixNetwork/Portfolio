---
import SectionHeader from "@components/SectionHeader.astro";
import { stats } from "@data/content";
---

<section class="section-band about" id="about" aria-labelledby="about-title">
  <div class="section-grid-bg" aria-hidden="true"></div>
  <div class="container about-layout">
    <div class="about-copy">
      <SectionHeader
        id="about-title"
        eyebrow="Operating Layer"
        title="Technical ownership for"
        highlight="digital launches."
        description="Torix Network designs and ships the practical layer behind online communities, creator businesses, startup tools, and campaign launches."
      />
      <p class="body-copy reveal">
        The work spans Telegram automation, responsive websites, web applications, API integrations, VPS operations, and growth infrastructure. Each build is scoped around the job it has to do, then documented well enough to keep moving after handoff.
      </p>
      <div class="stats-grid" aria-label="Torix Network capability highlights">
        {stats.map((stat) => (
          <div class="stat-card reveal">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    <figure class="about-visual reveal">
      <img
        src="/images/server-room-kewl-1280.jpg"
        alt="Server racks with network lights inside a dark data center."
        width="1280"
        height="854"
        loading="lazy"
        decoding="async"
      />
      <figcaption>
        <span>Infrastructure mindset</span>
        <strong>Automation, cloud, and launch support treated as one operating layer.</strong>
      </figcaption>
    </figure>
  </div>
</section>
